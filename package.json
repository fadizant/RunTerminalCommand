{
  "name": "terminal-commands-runner",
  "displayName": "Terminal Commands Runner by Fadi Abu Zant",
  "description": "Run predefined terminal commands from Explorer context menu or Command Palette.",
  "publisher": "fadizant-extensions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fadizant/RunTerminalCommand.git"
  },
  "icon": "img/icon.png",
  "version": "1.0.2",
  "engines": {
    "vscode": "^1.33.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Terminal",
    "CMD",
    "PowerShell",
    "Command",
    "Commands",
    "Shortcuts",
    "CLI",
    "Command Line",
    "Run"
  ],
  "activationEvents": [
    "onCommand:extension.terminalCommandsRunner"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "extension.terminalCommandsRunner",
        "key": "ctrl+alt+'"
      }
    ],
    "commands": [
      {
        "command": "extension.terminalCommandsRunner",
        "title": "Terminal Commands Runner..."
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.terminalCommandsRunner",
          "group": "navigation@6"
        }
      ]
    },
    "configuration": [
      {
        "title": "Terminal Commands Runner",
        "properties": {
          "terminalCommandsRunner.commands": {
            "type": "array",
            "items": {
              "type": [
                "object"
              ],
              "properties": {
                "command": {
                  "type": "string",
                  "description": "The text to send to the terminal. Use {resource}, {clipboard}, {#sym:Label} for free-text input, or {#opt:Label:option1,option2} for a dropdown picker."
                },
                "auto": {
                  "type": "boolean",
                  "description": "Whether to add a new line to the text being sent, this is normally required to run a command in the terminal."
                },
                "preserve": {
                  "type": "boolean",
                  "description": "Don't dispose of terminal running this command."
                },
                "fromRoot": {
                  "type": "boolean",
                  "description": "Open the terminal at the workspace root folder instead of the file's directory."
                },
                "name": {
                  "type": "string",
                  "description": "Name for the command. A human readable string which is rendered prominent."
                },
                "group": {
                  "type": "string",
                  "description": "Commands sharing the group name will be grouped together in the menu."
                }
              }
            },
            "default": [
              {
                  "command": "npm start",
                  "name": "Start Node.JS"
              },
              {
                  "command": "ndb server.js",
                  "auto": true,
                  "group": "Node.JS"
              },
              {
                  "command": "nodemon server.js",
                  "name": "Nodemon",
                  "auto": true,
                  "preserve": true,
                  "fromRoot": true,
                  "group": "Node.JS"
              },
              {
                  "command": "npm run start:{clipboard}",
                  "name": "Run with environments",
                  "auto": true,
                  "group": "Node.JS"
              },
              {
                  "command": "echo {resource}",
                  "auto": true
              },
              {
                  "command": "echo {#sym:Type something}",
                  "name": "User Input",
                  "auto": true
              },
              {
                  "command": "npm run {#opt:Choose script:start,build,test,lint}",
                  "name": "NPM Run (pick script)",
                  "auto": true
              }
            ]
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^2.2.42",
    "@types/node": "^10.12.21",
    "@types/vscode": "^1.33.0",
    "tslint": "^5.12.1",
    "typescript": "^3.9.10"
  }
}
